                "name": "workspaceId",
                "query": "SELECT \"workspaceId\" AS \"workspaceId\" FROM \"Membership\" WHERE \"userId\" = auth.user_id()"
              }
            }
          ],
          "row_filter": {
            "type": "and",
            "terms": [
              {
                "type": "or",
                "terms": [
                  {
                    "type": "is_null",
                    "operand": {
                      "type": "column",
                      "name": "archivedAt"
                    },
