===== multi_query_subscription_params =====
{
  "version": 1,
  "edition": 3,
  "compatibility_version": 1,
  "storage_version": 1,
  "streams": [
    {
      "name": "workspace",
      "source_table": "projects",
      "output_table": "projects",
      "auto_subscribe": false,
      "bucket_parameters": [
        {
          "name": "org_id",
          "source_column": "org_id",
          "binding": {
            "type": "subscription_parameter",
            "name": "org_id"
          }
        }
      ],
      "projection": {
        "type": "star"
      }
    },
    {
      "name": "inbox",
      "source_table": "tasks",
      "output_table": "tasks",
      "auto_subscribe": false,
      "bucket_parameters": [
        {
          "name": "org_id",
          "source_column": "org_id",
          "binding": {
            "type": "subscription_parameter",
            "name": "org_id"
          }
        }
      ],
      "projection": {
        "type": "star"
      },
      "data_queries": [
        {
          "source_table": "tasks",
          "output_table": "tasks",
          "bucket_parameters": [
            {
              "name": "org_id",
              "source_column": "org_id",
              "binding": {
                "type": "subscription_parameter",
                "name": "org_id"
              }
            }
          ],
          "projection": {
            "type": "star"
          }
        },
        {
          "source_table": "comments",
          "output_table": "comments",
          "bucket_parameters": [
            {
              "name": "org_id",
              "source_column": "org_id",
              "binding": {
                "type": "subscription_parameter",
                "name": "org_id"
              }
            }
          ],
          "projection": {
            "type": "columns",
            "columns": [
              {
                "source_column": "id",
                "alias": "comment_id"
              },
              {
                "source_column": "task_id",
                "alias": "task_id"
              },
              {
                "source_column": "org_id",
                "alias": "org_id"
              },
              {
                "source_column": "body",
                "alias": "body"
              }
            ]
          }
        }
      ]
    }
  ]
}

===== edition3_with_queries_and_request_filters =====
{
  "version": 1,
  "edition": 3,
  "compatibility_version": 1,
  "storage_version": 1,
  "streams": [
    {
      "name": "web_workspaces",
      "source_table": "Workspace",
      "output_table": "Workspace",
      "auto_subscribe": true,
      "bucket_parameters": [
        {
          "name": "workspaceId",
          "source_column": "workspaceId",
          "binding": {
            "type": "parameter_query_column",
            "name": "workspaceId",
            "query": "SELECT \"workspaceId\" AS \"workspaceId\" FROM \"Membership\" WHERE connection.parameters() ->> 'schema_version' = 'web' AND \"userId\" = auth.user_id() AND \"workspaceId\" IS NOT NULL AND \"teamId\" = connection.parameters() ->> 'selectedTeamId'"
          }
        },
        {
          "name": "selectedTeamId",
          "source_column": "selectedTeamId",
          "binding": {
            "type": "request_parameter",
            "name": "selectedTeamId"
          }
        }
      ],
      "row_filter": {
        "type": "is_null",
        "operand": {
          "type": "column",
          "name": "archivedAt"
        },
        "negated": false
      },
      "request_filter": {
        "type": "eq",
        "left": {
          "type": "binding",
          "binding": {
            "type": "request_parameter",
            "name": "schema_version"
          }
        },
        "right": {
          "type": "literal",
          "value": {
            "type": "string",
            "value": "web"
          }
        }
      },
      "projection": {
        "type": "star"
      },
      "data_queries": [
        {
          "source_table": "Workspace",
          "output_table": "Workspace",
          "bucket_parameters": [
            {
              "name": "workspaceId",
              "source_column": "id",
              "binding": {
                "type": "parameter_query_column",
                "name": "workspaceId",
                "query": "SELECT \"workspaceId\" AS \"workspaceId\" FROM \"Membership\" WHERE connection.parameters() ->> 'schema_version' = 'web' AND \"userId\" = auth.user_id() AND \"workspaceId\" IS NOT NULL AND \"teamId\" = connection.parameters() ->> 'selectedTeamId'"
              }
            }
          ],
          "row_filter": {
            "type": "is_null",
            "operand": {
              "type": "column",
              "name": "archivedAt"
            },
            "negated": false
          },
          "request_filter": {
            "type": "eq",
            "left": {
              "type": "binding",
              "binding": {
                "type": "request_parameter",
                "name": "schema_version"
              }
            },
            "right": {
              "type": "literal",
              "value": {
                "type": "string",
                "value": "web"
              }
            }
          },
          "projection": {
            "type": "star"
          }
        },
        {
          "source_table": "WorkspaceSetting",
          "output_table": "WorkspaceSetting",
          "bucket_parameters": [
            {
              "name": "selectedTeamId",
              "source_column": "teamId",
              "binding": {
                "type": "request_parameter",
                "name": "selectedTeamId"
              }
            }
          ],
          "row_filter": {
            "type": "or",
            "terms": [
              {
                "type": "is_null",
                "operand": {
                  "type": "column",
                  "name": "archivedAt"
                },
                "negated": false
              },
              {
                "type": "is_null",
                "operand": {
                  "type": "column",
                  "name": "flagValue"
                },
                "negated": true
              }
            ]
          },
          "request_filter": {
            "type": "eq",
            "left": {
              "type": "binding",
              "binding": {
                "type": "request_parameter",
                "name": "schema_version"
              }
            },
            "right": {
              "type": "literal",
              "value": {
                "type": "string",
                "value": "web"
              }
            }
          },
          "projection": {
            "type": "star"
          }
        }
      ]
    },
    {
      "name": "web_generic",
      "source_table": "Document",
      "output_table": "Document",
      "auto_subscribe": false,
      "bucket_parameters": [],
      "request_filter": {
        "type": "or",
        "terms": [
          {
            "type": "eq",
            "left": {
              "type": "binding",
              "binding": {
                "type": "request_parameter",
                "name": "schema_version"
              }
            },
            "right": {
              "type": "literal",
              "value": {
                "type": "string",
                "value": "web"
              }
            }
          },
          {
            "type": "eq",
            "left": {
              "type": "binding",
              "binding": {
                "type": "request_parameter",
                "name": "schema_version"
              }
            },
            "right": {
              "type": "literal",
              "value": {
                "type": "string",
                "value": "mobile"
              }
            }
          }
        ]
      },
      "projection": {
        "type": "star"
      },
      "data_queries": [
        {
          "source_table": "Document",
          "output_table": "Document",
          "bucket_parameters": [],
          "request_filter": {
            "type": "or",
            "terms": [
              {
                "type": "eq",
                "left": {
                  "type": "binding",
                  "binding": {
                    "type": "request_parameter",
                    "name": "schema_version"
                  }
                },
                "right": {
                  "type": "literal",
                  "value": {
                    "type": "string",
                    "value": "web"
                  }
                }
              },
              {
                "type": "eq",
                "left": {
                  "type": "binding",
                  "binding": {
                    "type": "request_parameter",
                    "name": "schema_version"
                  }
                },
                "right": {
                  "type": "literal",
                  "value": {
                    "type": "string",
                    "value": "mobile"
                  }
                }
              }
            ]
          },
          "projection": {
            "type": "star"
          }
        }
      ]
    }
  ]
}

