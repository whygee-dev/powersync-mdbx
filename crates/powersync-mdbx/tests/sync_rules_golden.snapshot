===== computed_id_star_projection =====
{
  "version": 1,
  "edition": 3,
  "compatibility_version": 1,
  "storage_version": 1,
  "streams": [
    {
      "name": "issue_label",
      "source_table": "_IssueToLabel",
      "output_table": "_IssueToLabel",
      "auto_subscribe": false,
      "bucket_parameters": [
        {
          "name": "teamId",
          "source_column": "teamId",
          "binding": {
            "type": "subscription_parameter",
            "name": "teamId"
          }
        }
      ],
      "projection": {
        "type": "star_with_computed",
        "computed": [
          {
            "alias": "id",
            "expression": {
              "terms": [
                {
                  "type": "column",
                  "source_column": "A"
                },
                {
                  "type": "literal",
                  "value": "."
                },
                {
                  "type": "column",
                  "source_column": "B"
                }
              ]
            }
          }
        ]
      }
    }
  ]
}

